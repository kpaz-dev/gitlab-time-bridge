# --- App server ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- GitLab Webhook ---
# Token secreto para validar la cabecera X-Gitlab-Token del webhook
GITLAB_WEBHOOK_SECRET=mi-secreto

# --- Teamwork API ---
# URL base de tu cuenta Teamwork (sin "/" final)
TEAMWORK_BASE_URL=https://miempresa.teamwork.com

# Token de API de Teamwork. Si lo dejas vacío, el servicio opera en dry-run
# (solo logs, no hace llamadas reales a la API)
TEAMWORK_API_TOKEN=

# Forzar modo dry-run (true/false). Si no hay TEAMWORK_API_TOKEN, se asume true
TEAMWORK_DRY_RUN=true

# Mapas opcionales para resolver proyecto/usuario desde GitLab → Teamwork
# Puedes mapear por id de proyecto GitLab o por path con namespace.
# También puedes definir una clave "default".
# Ejemplos:
TEAMWORK_PROJECT_MAP_JSON={"pilma/pilma-suite":"99999","default":"99999"}
TEAMWORK_USER_MAP_JSON={"jperez":"111"}
